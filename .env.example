# WisDev open-source local defaults.
# Put real secret values in your shell or a local .env file that is not committed.

WISDEV_CONFIG=config/wisdev.example.yaml
WISDEV_MODEL_CONFIG=config/wisdev_models.example.json
WISDEV_STATE_DIR=.wisdev/state
WISDEV_JOURNAL_PATH=.wisdev/wisdev_journal.jsonl
WISDEV_ORCHESTRATOR_URL=http://127.0.0.1:8081
WISDEV_MODE=yolo
WISDEV_LLM_API_KEY=
WISDEV_LLM_BASE_URL=http://127.0.0.1:11434/v1
WISDEV_LLM_MODEL=llama3.1
PYTHON_SIDECAR_HTTP_URL=http://127.0.0.1:8090
PYTHON_SIDECAR_GRPC_ADDR=127.0.0.1:50052
TEMPORAL_ENABLED=false
