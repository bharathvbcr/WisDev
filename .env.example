# WisDev Agent - Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# LLM Configuration
WISDEV_LLM_API_KEY=sk-your-api-key-here

# Service-to-Service Authentication (optional)
INTERNAL_SERVICE_KEY=

# OpenTelemetry (optional - used when observability.enable_otel=true)
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Logging
LOG_LEVEL=info

# Embedding API (optional - for semantic cache)
EMBEDDING_API_URL=
